# Copy to .env and fill in values.
# OpenAI: https://platform.openai.com/api-keys

FLASK_SECRET_KEY=change-this-to-a-long-random-string
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: set to 1 to disable OpenAI and use keyword fallbacks only
AI_DISABLED=0
FLASK_DEBUG=0
# Optional: avoid startup embedding refresh unless you explicitly want it
AUTO_REINDEX_ON_STARTUP=0
# Optional: set to 0 if you never want seed checks on boot
SEED_ON_STARTUP=1
EXPOSE_RESET_TOKEN=1

# Chatbot cost controls (recommended for free-tier API usage)
AI_CHAT_MODEL=gpt-4o-mini
AI_CHAT_MAX_TOKENS=120
AI_CHAT_TEMPERATURE=0.2
AI_CHAT_RATE_LIMIT_PER_10_MIN=25
AI_CHAT_CACHE_SECONDS=900
AI_CHAT_QUOTA_COOLDOWN_SECONDS=1800
AI_CHAT_RATE_LIMIT_COOLDOWN_SECONDS=90
AI_EMBED_FOR_SMART_SEARCH=0
AI_EMBED_MODEL=text-embedding-3-small

# Payments (Razorpay)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

# Deployment / CORS
ORIGIN=http://localhost:3000
PUBLIC_BACKEND_URL=http://127.0.0.1:5000
HOST=0.0.0.0
PORT=5000
SESSION_COOKIE_SECURE=0
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_SECURE=0
REMEMBER_COOKIE_SAMESITE=Lax

# Image uploads (Cloudinary preferred for deployed apps)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=automart
IMAGE_MAX_MB=6
RAW_IMAGE_MAX_MB=20

# SQLite (default). For MySQL use:
# DATABASE_URL=mysql+pymysql://user:pass@localhost/spare_parts
DATABASE_URL=
