# Frontend Environment Variables
# Copy to .env.local and configure

# Backend API rewrite target (used by next.config.js)
# Local: http://127.0.0.1:5000
# Production: your hosted backend URL (for example Render service URL)
BACKEND_URL=http://127.0.0.1:5000

# Payments
# Optional fallback. Primary key is served from backend /api/payments/config.
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_YOUR_KEY_ID

# PWA
NEXT_PUBLIC_APP_NAME="AutoMart - Cars & Bikes"
NEXT_PUBLIC_APP_DESCRIPTION="Premium cars and bikes marketplace with AI assistant"

